# Build output
/build/
/out/
/bin/
/classes/

# IDE
/.idea/
*.iml

# MyEclipse project config (tracked for team consistency)
# .project, .classpath, .settings, .mymetadata are allowed
!.project
!.classpath
!.settings/
!.mymetadata

# MyEclipse local metadata (not tracked)
/.myeclipse/

# Java
*.class
*.jar
!web/WEB-INF/lib/*.jar

# OS
.DS_Store
Thumbs.db

# Temp
*.log
*.tmp
/temp/

# RAR/ZIP
*.rar
*.zip
!web/WEB-INF/lib/*.zip

# Large binaries - do not commit
mysql/navicat121_premium_cs_x64.exe
mysql/mysql.zip
/mysql/mysql_extracted/
/HBuilder/

# Tomcat / JDK runtime
/tomcat9/
/jdk8/
